<DefaultWindow SetSize="520 430" MinSize="420 330" xmlns="https://spacestation14.io">
    <BoxContainer Orientation="Vertical" Margin="6">
        <BoxContainer Orientation="Horizontal" Margin="0 0 0 4">
            <OptionButton Name="MarkKindOption" HorizontalExpand="True" />
            <Button Name="RefreshButton" Text="{Loc 'cmu-yautja-mark-refresh'}" Margin="4 0 0 0" />
        </BoxContainer>
        <LineEdit Name="ReasonEdit" PlaceHolder="{Loc 'cmu-yautja-mark-reason-placeholder'}" Margin="0 0 0 4" />
        <ItemList Name="TargetList" Access="Public" VerticalExpand="True" SelectMode="Single" />
        <BoxContainer Orientation="Horizontal" Margin="0 4 0 0">
            <Button Name="MarkButton" Text="{Loc 'cmu-yautja-mark-apply'}" HorizontalExpand="True" />
            <Button Name="UnmarkButton" Text="{Loc 'cmu-yautja-mark-remove'}" HorizontalExpand="True" Margin="4 0 0 0" />
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
